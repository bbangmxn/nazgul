# Local PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/nazgul
DB_USERNAME=nazgul
DB_PASSWORD=nazgul
DB_SCHEMA=public
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_POOL_CONNECTION_TIMEOUT_MS=30000

# Supabase PostgreSQL (optional override)
SUPABASE_DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_USERNAME=postgres
SUPABASE_DB_PASSWORD=
SUPABASE_DB_SCHEMA=public
FLYWAY_ENABLED=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2s

# OpenAI / Spring AI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
PGVECTOR_DIMENSIONS=1536

# Ollama
APP_RAG_OLLAMA_ENABLED=true
APP_RAG_OLLAMA_BASE_URL=http://localhost:11434
APP_RAG_OLLAMA_CHAT_MODEL=qwen3:8b
APP_RAG_OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
APP_RAG_OLLAMA_TIMEOUT_MS=60000

# Optimization Worker
OPTIMIZATION_WORKER_ENABLED=true
OPTIMIZATION_WORKER_DELAY_MS=30000
OPTIMIZATION_LOCK_TTL_SECONDS=300
OPTIMIZATION_BATCH_SIZE=5

# Server
SERVER_PORT=8080
